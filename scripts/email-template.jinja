<html>
<head>
    <style>

        body {
            font-family: Arial, sans-serif;
            line-height: 1.5;
        }

        .success {
            color: green;
            font-weight: bold;
        }

        .failed {
            color: red;
            font-weight: bold;
        }

        .cancelled {
            color: orange;
            font-weight: bold;
        }

        table {
            border-collapse: collapse;
            width: 60%;
        }

        table, th, td {
            border: 1px solid #dddddd;
            padding: 8px;
        }

        th {
            background-color: #f2f2f2;
            text-align: left;
        }

        .approve-btn {
            background-color: green;
            color: white !important;
            padding: 14px 24px;
            text-decoration: none;
            border-radius: 6px;
            font-weight: bold;
            display: inline-block;
        }

    </style>
</head>

<body>

    <p>Hello {{ name }},</p>

    <p>
        The build job for
        <strong>{{ service_name }}</strong>
        has completed successfully:
    </p>

    <h3>Build Details</h3>

    <table>

        <tr>
            <th>Build Number</th>
            <td>{{ build_number }}</td>
        </tr>

        <tr>
            <th>Build Time</th>
            <td>{{ build_time }}</td>
        </tr>

        <tr>
            <th>Services/Libraries</th>
            <td>{{ service_name }}</td>
        </tr>

    </table>

    <br><br>

    <p>
        Please approve deployment:
    </p>

    <a
       href="{{ approval_url }}?service={{ service_name }}"
       class="approve-btn">
       APPROVE DEPLOYMENT
    </a>

    <br><br>

    <p>
        Thanks & Regards,<br>
        DevOps Team
    </p>

</body>
</html>
